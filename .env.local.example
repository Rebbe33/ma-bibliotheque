# Supabase — récupérez ces valeurs dans Settings > API de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Google Books API (optionnel — améliore les quotas)
# Obtenez une clé sur https://console.developers.google.com
# NEXT_PUBLIC_GOOGLE_BOOKS_KEY=VOTRE_CLE_API
